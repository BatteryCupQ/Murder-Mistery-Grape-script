-- Часть 7: Sounds - звук при ходьбе
local soundEnabled = false
local walkSound = Instance.new("Sound")
walkSound.SoundId = "rbxassetid://9120386436" -- замени на ID стонов аниме-тянки
walkSound.Volume = 1
walkSound.Looped = false

local function onWalk()
    if not soundEnabled then return end
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        local hum = char.Humanoid
        if hum.MoveDirection.Magnitude > 0 then
            if not walkSound.IsPlaying then
                walkSound:Play()
            end
        else
            walkSound:Stop()
        end
    end
end

game:GetService("RunService").RenderStepped:Connect(onWalk)

local sframe = Instance.new("Frame", contentSounds)
sframe.Size = UDim2.new(1,-20,1,-20)
sframe.Position = UDim2.new(0,10,0,10)
sframe.BackgroundTransparency = 1

local sbtn = Instance.new("TextButton", sframe)
sbtn.Size = UDim2.new(0,200,0,40)
sbtn.Position = UDim2.new(0.5,-100,0.4,-20)
sbtn.BackgroundColor3 = themes[currentTheme].btn
sbtn.Text = "Стоны аниме-тянки OFF"
sbtn.TextColor3 = themes[currentTheme].text
sbtn.Font = Enum.Font.GothamBold
sbtn.TextSize = 13
Instance.new("UICorner", sbtn).CornerRadius = UDim.new(0,8)

local soundState = false
sbtn.MouseButton1Click:Connect(function()
    soundState = not soundState
    soundEnabled = soundState
    sbtn.Text = soundState and "Стоны аниме-тянки ON" or "Стоны аниме-тянки OFF"
    sbtn.BackgroundColor3 = soundState and themes[currentTheme].accent or themes[currentTheme].btn
end)

walkSound.Parent = player:WaitForChild("PlayerGui")

