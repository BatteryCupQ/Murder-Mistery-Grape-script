local btnAimbot = addCategory("🔫 Aimbot", 90)
local btnMisc = addCategory("🕵️ Misc", 125)
local btnAuthor = addCategory("👤 Author", 160)
local btnSettings = addCategory("⚙ Settings", 195)
local btnSounds = addCategory("🔊 Sounds", 230)

local function setActive(b)
    for _,v in pairs({btnVisuals,btnAimbot,btnMisc,btnAuthor,btnSettings,btnSounds}) do
        v.BackgroundColor3 = themes[currentTheme].btn
        v.TextColor3 = themes[currentTheme].text
    end
    b.BackgroundColor3 = themes[currentTheme].accent
    b.TextColor3 = Color3.fromRGB(255,255,255)
end

