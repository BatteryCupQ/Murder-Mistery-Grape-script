print("✅ Часть 3 готова")
-- Часть 4: Вкладка Misc - показывает роли всех игроков
local roleLabels = {}
local function updateRoles()
    for _,lbl in pairs(roleLabels) do lbl:Remove() end
    roleLabels = {}
    local y = 10
    for _,p in pairs(game.Players:GetPlayers()) do
        local lbl = Instance.new("TextLabel", contentMisc)
        lbl.Size = UDim2.new(1,-20,0,22)
        lbl.Position = UDim2.new(0,10,0,y)
        lbl.BackgroundTransparency = 1
        local role = getRole(p)
        lbl.Text = p.Name.." - "..role
        lbl.TextColor3 = role=="Murderer" and Color3.fromRGB(255,0,0) or (role=="Sheriff" and Color3.fromRGB(0,100,255) or Color3.fromRGB(200,200,200))
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 12
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        roleLabels[lbl] = true
        y = y + 24
    end
    contentMisc.CanvasSize = UDim2.new(0,0,0,y+20)
end

-- Обновление каждые 2 секунды
spawn(function() while task.wait(2) do updateRoles() end end)

print("✅ Часть 4 готова")
