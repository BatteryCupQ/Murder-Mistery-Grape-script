-- Часть 3: Aimbot Murder Mystery
local aim = {enabled=false, silent=false, fov=200, smooth=5, autoShoot=false}
local aimConn

local function getRole(plr)
    -- Ищем роль в Murder Mystery
    local roleObj = plr:FindFirstChild("Role") -- может быть StringValue
    if roleObj and roleObj:IsA("StringValue") then return roleObj.Value end
    local attr = plr:GetAttribute("Role")
    if attr then return attr end
    -- Дополнительные проверки
    local char = plr.Character
    if char then
        local tag = char:FindFirstChild("RoleTag") -- иногда
        if tag then return tag.Value end
    end
    return "Innocent"
end

local function getMurderer()
    for _,p in pairs(game.Players:GetPlayers()) do
        if getRole(p) == "Murderer" then
            return p
        end
    end
    return nil
end

local function isSheriff()
    return getRole(player) == "Sheriff"
end

local function hasRevolver()
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool and (tool.Name:lower():find("revolver") or tool.Name:lower():find("gun")) then
            return true
        end
    end
    return false
end

local function aimbotFunc()
    if not aim.enabled then return end
    if not isSheriff() then return end
    if not hasRevolver() then return end
    local murderer = getMurderer()
    if not murderer or not murderer.Character then return end
    local target = murderer.Character:FindFirstChild("Head")
    if not target then return end
    local cam = workspace.CurrentCamera
    local pos = target.Position
    if aim.silent then
        -- Silent aim через изменение CFrame оружия
        local char = player.Character
        if char then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Handle") then
                tool.Handle.CFrame = CFrame.new(tool.Handle.Position, pos)
                if aim.autoShoot then
                    -- Авто-выстрел через VirtualInputManager
                    pcall(function()
                        local vim = game:GetService("VirtualInputManager")
                        vim:SendMouseButtonEvent(0,0,0,true,nil,0)
                        task.wait(0.05)
                        vim:SendMouseButtonEvent(0,0,0,false,nil,0)
                    end)
                end
                task.wait()
                pcall(function() tool.Handle.CFrame = tool.Handle.CFrame end)
            end
        end
    else
        -- Обычное наведение
        cam.CFrame = CFrame.new(cam.CFrame.Position, pos)
        if aim.autoShoot then
            pcall(function()
                local vim = game:GetService("VirtualInputManager")
                vim:SendMouseButtonEvent(0,0,0,true,nil,0)
                task.wait(0.05)
                vim:SendMouseButtonEvent(0,0,0,false,nil,0)
            end)
        end
    end
end

function updateAimbot()
    if aimConn then aimConn:Disconnect() end
    if aim.enabled then
        aimConn = game:GetService("RunService").RenderStepped:Connect(aimbotFunc)
    end
end

-- Интерфейс вкладки Aimbot
