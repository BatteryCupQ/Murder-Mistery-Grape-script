-- Часть 2: Вкладка Visuals с динамическим превью
local esp = {enabled=false, boxes=true, skeleton=false, health=true, tracers=false, names=true, trail=false, trailColor=Color3.fromRGB(255,50,50)}
local drawings = {}

local function clearESP()
    for _,d in pairs(drawings) do pcall(function() d:Remove() end) end
    drawings = {}
end

local function drawESP()
    clearESP()
    if not esp.enabled then return end
    local cam = workspace.CurrentCamera
    for _,plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if head and hrp then
                local pos, on = cam:WorldToViewportPoint(head.Position)
                if on then
                    if esp.boxes then
                        local b = Drawing.new("Square")
                        b.Position = Vector2.new(pos.X-20, pos.Y-30)
                        b.Size = Vector2.new(40,55)
                        b.Color = Color3.fromRGB(255,50,50)
                        b.Thickness = 2
                        b.Filled = false
                        b.Visible = true
                        table.insert(drawings,b)
                    end
                    if esp.skeleton and plr.Character then
                        local connections = {{"Head","UpperTorso"},{"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"UpperTorso","LowerTorso"},{"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"}}
                        for _,p in ipairs(connections) do
                            local p1,p2 = plr.Character:FindFirstChild(p[1]), plr.Character:FindFirstChild(p[2])
                            if p1 and p2 then
                                local a = cam:WorldToViewportPoint(p1.Position)
                                local b = cam:WorldToViewportPoint(p2.Position)
                                local line = Drawing.new("Line")
                                line.From = Vector2.new(a.X,a.Y)
                                line.To = Vector2.new(b.X,b.Y)
                                line.Color = Color3.fromRGB(255,255,255)
                                line.Thickness = 1
                                line.Visible = true
                                table.insert(drawings,line)
                            end
                        end
                    end
                    if esp.health then
                        local hum = plr.Character:FindFirstChild("Humanoid")
                        if hum then
                            local pct = hum.Health/hum.MaxHealth
                            local bg = Drawing.new("Line")
                            bg.From = Vector2.new(pos.X-22, pos.Y-35)
                            bg.To = Vector2.new(pos.X+22, pos.Y-35)
                            bg.Color = Color3.fromRGB(50,50,50)
                            bg.Thickness = 3
                            bg.Visible = true
                            table.insert(drawings,bg)
                            local fill = Drawing.new("Line")
                            fill.From = Vector2.new(pos.X-22, pos.Y-35)
                            fill.To = Vector2.new(pos.X-22+44*pct, pos.Y-35)
                            fill.Color = pct>0.5 and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                            fill.Thickness = 3
                            fill.Visible = true
                            table.insert(drawings,fill)
                        end
                    end
                    if esp.tracers then
                        local l = Drawing.new("Line")
                        l.From = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
                        l.To = Vector2.new(pos.X, pos.Y)
                        l.Color = esp.trailColor
                        l.Thickness = 1
                        l.Visible = true
                        table.insert(drawings,l)
                    end
                    if esp.names then
                        local t = Drawing.new("Text")
                        t.Text = plr.Name
                        t.Position = Vector2.new(pos.X, pos.Y-43)
                        t.Size = 12
                        t.Color = Color3.fromRGB(255,255,255)
                        t.Center = true
                        t.Visible = true
                        table.insert(drawings,t)
                    end
                end
            end
        end
    end
end

game:GetService("RunService").RenderStepped:Connect(function() if esp.enabled then drawESP() end end)

