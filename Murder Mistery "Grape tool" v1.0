createToggle("Enabled", ascroll, false, function(s) aim.enabled = s; updateAimbot() end)
createToggle("Silent Aim", ascroll, false, function(s) aim.silent = s end)
createToggle("Auto Shoot", ascroll, false, function(s) aim.autoShoot = s end)
