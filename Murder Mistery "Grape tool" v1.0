-- Часть 6: Settings - переключение темы
local themeToggle
local function applyTheme(theme)
    currentTheme = theme
    main.BackgroundColor3 = themes[theme].bg
    left.BackgroundColor3 = themes[theme].left
    title.TextColor3 = themes[theme].accent
    div.BackgroundColor3 = themes[theme].accent
    for _,b in pairs({btnVisuals,btnAimbot,btnMisc,btnAuthor,btnSettings,btnSounds}) do
        b.BackgroundColor3 = themes[theme].btn
        b.TextColor3 = themes[theme].text
    end
    -- Перекраска активной кнопки
    setActive(btnSettings) -- временно, потом переключим обратно
    -- ... (громоздко, оставим упрощённо)
end

