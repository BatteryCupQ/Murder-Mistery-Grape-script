-- Определение роли
function getRole(plr)
    if plr:FindFirstChild("Murderer") then return "Murderer" end
    if plr:FindFirstChild("Sheriff") then return "Sheriff" end
    local roleObj = plr:FindFirstChild("Role")
    if roleObj and roleObj:IsA("StringValue") then return roleObj.Value end
    if plr:GetAttribute("Role") then return plr:GetAttribute("Role") end
    local char = plr.Character
    if char then
        local tag = char:FindFirstChild("RoleTag") or char:FindFirstChild("MurdererTag")
        if tag then
            if tag:IsA("BoolValue") and tag.Value then return "Murderer" end
            if tag:IsA("StringValue") then return tag.Value end
        end
    end
    return "Innocent"
end

function getMurderer()
    for _,p in pairs(game.Players:GetPlayers()) do
        if getRole(p) == "Murderer" then return p end
    end
    return nil
end

function isSheriff()
    return getRole(player) == "Sheriff"
end

function hasRevolver()
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool and (tool.Name:lower():find("revolver") or tool.Name:lower():find("gun")) then
            return true
        end
    end
    return false
end

-- Настройки аимбота
local aim = {enabled=false, silent=false, fov=200, smooth=5, autoShoot=false}
local aimbotConnection = nil

function stopAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
end

function startAimbot()
    stopAimbot()
    if not aim.enabled then return end
    aimbotConnection = RS.RenderStepped:Connect(function()
        if not aim.enabled then return end
        if not isSheriff() then return end
        if not hasRevolver() then return end
        local murderer = getMurderer()
        if not murderer or not murderer.Character then return end
        local targetPart = murderer.Character:FindFirstChild("Head")
        if not targetPart then return end

        local camera = workspace.CurrentCamera
        local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen then return end
        local screenCenter = camera.ViewportSize / 2
        local distFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if distFromCenter > aim.fov then return end

        local targetPos = targetPart.Position
        if aim.silent then
            local char = player.Character
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Handle") then
                    tool.Handle.CFrame = CFrame.new(tool.Handle.Position, targetPos)
                    if aim.autoShoot then
                        pcall(function()
                            game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,true,nil,0)
                            task.wait(0.05)
                            game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,false,nil,0)
                        end)
                    end
                    task.wait()
                    pcall(function() tool.Handle.CFrame = tool.Handle.CFrame end)
                end
            end
        else
            local desiredCF = CFrame.new(camera.CFrame.Position, targetPos)
            if aim.smooth > 0 then
                camera.CFrame = camera.CFrame:Lerp(desiredCF, 1/aim.smooth)
            else
                camera.CFrame = desiredCF
            end
            if aim.autoShoot then
                pcall(function()
                    game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,true,nil,0)
                    task.wait(0.05)
                    game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,false,nil,0)
                end)
            end
        end
    end)
end

function updateAimbot()
    stopAimbot()
    if aim.enabled then startAimbot() end
end

