-- Функция обновления темы
function updateTheme()
    local t = themes[currentTheme]
    main.BackgroundColor3 = t.bg
    left.BackgroundColor3 = t.left
    title.TextColor3 = t.accent
    divider.BackgroundColor3 = t.accent
    for _,b in ipairs(allCategories) do
        if b.BackgroundColor3 ~= t.accent then
            b.BackgroundColor3 = t.btn
            b.TextColor3 = t.text
        end
    end
    espScroll.ScrollBarImageColor3 = t.scroll
    aimbotScroll.ScrollBarImageColor3 = t.scroll
    previewFrame.BackgroundColor3 = t.btn
    previewTitle.TextColor3 = t.accent
end

