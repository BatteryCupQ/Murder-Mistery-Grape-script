local function footstepCheck()
    if not soundEnabled then return end
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        local hum = char.Humanoid
        if hum.MoveDirection.Magnitude > 0 then
            if not moanSound.IsPlaying then moanSound:Play() end
        else
            if moanSound.IsPlaying then moanSound:Stop() end
        end
    end
end
RS.RenderStepped:Connect(footstepCheck)

