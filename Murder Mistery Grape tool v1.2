-- Улучшенное определение роли
function getRole(plr)
    -- Прямые BoolValue в плеере
    if plr:FindFirstChild("Murderer") then return "Murderer" end
    if plr:FindFirstChild("Sheriff") then return "Sheriff" end
    -- StringValue Role
    local rv = plr:FindFirstChild("Role")
    if rv and rv:IsA("StringValue") then return rv.Value end
    -- Атрибуты
    if plr:GetAttribute("Role") then return plr:GetAttribute("Role") end
    -- Поиск в Backpack (иногда там лежит Gun)
    local bp = plr:FindFirstChild("Backpack")
    if bp then
        if bp:FindFirstChild("Gun") or bp:FindFirstChild("Revolver") then return "Sheriff" end
        if bp:FindFirstChild("Knife") then return "Murderer" end
    end
    -- По тегам в Character
    local char = plr.Character
    if char then
        local tag = char:FindFirstChild("MurdererTag") or char:FindFirstChild("SheriffTag")
        if tag and tag:IsA("BoolValue") and tag.Value then
            return tag.Name == "MurdererTag" and "Murderer" or "Sheriff"
        end
    end
    return "Innocent"
end

function getMurderer()
    for _,p in pairs(game.Players:GetPlayers()) do
        if getRole(p) == "Murderer" then return p end
    end
    return nil
end

function isSheriff()
    local role = getRole(player)
    print("Моя роль: "..role) -- отладка
    return role == "Sheriff"
end

function hasRevolver()
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool and (tool.Name:lower():find("revolver") or tool.Name:lower():find("gun") or tool.Name:lower():find("pistol")) then
            return true
        end
    end
    return false
end

-- Настройки аимбота
local aim = {enabled=false, silent=false, fov=200, smooth=5, autoShoot=false}
local aimbotConnection = nil

function stopAimbot()
    if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
end

function startAimbot()
    stopAimbot()
    if not aim.enabled then return end
    aimbotConnection = RS.RenderStepped:Connect(function()
        if not aim.enabled then return end
        if not isSheriff() then return end
        if not hasRevolver() then print("Нет револьвера") return end
        local target = getMurderer()
        if not target or not target.Character then print("Убийца не найден") return end
        local head = target.Character:FindFirstChild("Head")
        if not head then return end

        local camera = workspace.CurrentCamera
        local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
        if not onScreen then return end
        local center = camera.ViewportSize/2
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist > aim.fov then return end

        if aim.silent then
            local char = player.Character
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Handle") then
                    tool.Handle.CFrame = CFrame.new(tool.Handle.Position, head.Position)
                    if aim.autoShoot then
                        pcall(function()
                            local vim = game:GetService("VirtualInputManager")
                            vim:SendMouseButtonEvent(0,0,0,true,nil,0) task.wait(0.05) vim:SendMouseButtonEvent(0,0,0,false,nil,0)
                        end)
                    end
                    task.wait()
                    pcall(function() tool.Handle.CFrame = tool.Handle.CFrame end)
                end
            end
        else
            local desired = CFrame.new(camera.CFrame.Position, head.Position)
            if aim.smooth > 0 then camera.CFrame = camera.CFrame:Lerp(desired, 1/aim.smooth)
            else camera.CFrame = desired end
            if aim.autoShoot then
                pcall(function()
                    local vim = game:GetService("VirtualInputManager")
                    vim:SendMouseButtonEvent(0,0,0,true,nil,0) task.wait(0.05) vim:SendMouseButtonEvent(0,0,0,false,nil,0)
                end)
            end
        end
    end)
    print("Аимбот запущен")
end

function updateAimbot()
    stopAimbot()
    if aim.enabled then startAimbot() end
end

